import React, { useRef, useEffect, useState } from 'react';
import { Stage, Layer, Image as KonvaImage, Line } from 'react-konva';
import { useSceneStore } from './Smart2Dcanvas_SceneStore';
import useImage from 'use-image';
import { v4 as uuidv4 } from 'uuid';

// Wrapper component to handle useImage hook correctly inside Konva
const UnderlayImageRenderer: React.FC<{
  source: string;
  x: number;
  y: number;
  opacity: number;
  scaleX: number;
  scaleY: number;
  rotation: number;
}> = ({ source, x, y, opacity, scaleX, scaleY, rotation }) => {
  const [image] = useImage(source);
  return image ? (
    <KonvaImage
      image={image}
      x={x}
      y={y}
      opacity={opacity}
      scaleX={scaleX}
      scaleY={scaleY}
      rotation={rotation}
    />
  ) : null;
};

const Smart2Dcanvas_CanvasViewport: React.FC = () => {
  const containerRef = useRef<HTMLDivElement>(null);
  const [dimensions, setDimensions] = useState({ width: 0, height: 0 });

  const scale = useSceneStore((state) => state.scale);
  const panX = useSceneStore((state) => state.panX);
  const panY = useSceneStore((state) => state.panY);
  const setScale = useSceneStore((state) => state.setScale);
  const setPan = useSceneStore((state) => state.setPan);
  const activeTool = useSceneStore((state) => state.activeTool);
  const underlayImages = useSceneStore((state) => state.underlayImages);
  const addSegment = useSceneStore((state) => state.addSegment);
  const segments = useSceneStore((state) => state.segments);
  const selectObject = useSceneStore((state) => state.selectObject);
  const selectedIds = useSceneStore((state) => state.selectedIds);
  
  const stageRef = useRef<any>(null);
  const [isPanning, setIsPanning] = useState(false);
  const [panStart, setPanStart] = useState({ x: 0, y: 0 });

  // Drafting state
  const [isDrawing, setIsDrawing] = useState(false);
  const [draftPoints, setDraftPoints] = useState<{x: number, y: number}[]>([]);

  const handleWheel = (e: any) => {
    e.evt.preventDefault();
    const stage = stageRef.current;
    if (!stage) return;

    const scaleBy = 1.1;
    const oldScale = stage.scaleX();
    const pointer = stage.getPointerPosition();
    
    if (!pointer) return;

    const mousePointTo = {
      x: (pointer.x - stage.x()) / oldScale,
      y: (pointer.y - stage.y()) / oldScale,
    };

    // Zoom in or out depending on deltaY
    const newScale = e.evt.deltaY < 0 ? oldScale * scaleBy : oldScale / scaleBy;

    setScale(newScale);

    const newPos = {
      x: pointer.x - mousePointTo.x * newScale,
      y: pointer.y - mousePointTo.y * newScale,
    };
    
    setPan(newPos.x, newPos.y);
  };

  const getRelativePointerPosition = () => {
    const stage = stageRef.current;
    if (!stage) return { x: 0, y: 0 };
    const pointer = stage.getPointerPosition();
    if (!pointer) return { x: 0, y: 0 };

    return {
      x: (pointer.x - stage.x()) / stage.scaleX(),
      y: (pointer.y - stage.y()) / stage.scaleY(),
    };
  };

  const handlePointerDown = (e: any) => {
    // Middle mouse button or Pan tool
    if (e.evt.button === 1 || activeTool === 'pan') {
      setIsPanning(true);
      setPanStart({ x: e.evt.clientX, y: e.evt.clientY });
      
      const stage = stageRef.current;
      if (stage) {
        stage.container().style.cursor = 'grabbing';
      }
      return;
    }

    if (activeTool === 'line') {
      const pos = getRelativePointerPosition();
      setIsDrawing(true);
      setDraftPoints([pos, pos]);
    }
    
    if (activeTool === 'select') {
      // Basic empty click clears selection, object click is handled by object itself
      if (e.target === e.target.getStage()) {
        useSceneStore.getState().clearSelection();
      }
    }
  };

  const handlePointerMove = (e: any) => {
    if (isPanning) {
      const dx = e.evt.clientX - panStart.x;
      const dy = e.evt.clientY - panStart.y;
      
      setPan(panX + dx, panY + dy);
      setPanStart({ x: e.evt.clientX, y: e.evt.clientY });
      return;
    }

    if (activeTool === 'line' && isDrawing) {
      const pos = getRelativePointerPosition();
      setDraftPoints([draftPoints[0], pos]);
    }
  };

  const handlePointerUp = () => {
    if (isPanning) {
      setIsPanning(false);
      const stage = stageRef.current;
      if (stage) {
        stage.container().style.cursor = activeTool === 'pan' ? 'grab' : 'crosshair';
      }
      return;
    }

    if (activeTool === 'line' && isDrawing) {
      setIsDrawing(false);
      const pos = getRelativePointerPosition();
      const currentElevation = useSceneStore.getState().currentElevation;
      
      // Avoid tiny/zero-length lines in 2D space unless it's a pure vertical riser
      const dx = draftPoints[0].x - pos.x;
      const dy = draftPoints[0].y - pos.y;
      
      // Note: In a full CAD app, if dx/dy is 0 but dz is large, we still add it (as a riser).
      // For now we assume if they drag even slightly it's a segment.
      if (Math.sqrt(dx * dx + dy * dy) > 2) {
        const newSegId = uuidv4();
        addSegment({
          id: newSegId,
          startNodeId: uuidv4(),
          endNodeId: uuidv4(),
          geometryKind: 'line',
          points: [
            // Start point uses elevation 0 for now (or could track previous elevation)
            { id: uuidv4(), x: draftPoints[0].x, y: draftPoints[0].y, z: currentElevation },
            { id: uuidv4(), x: pos.x, y: pos.y, z: currentElevation },
          ],
        });
      }
      setDraftPoints([]);
    }
  };

  // Resize handler
  useEffect(() => {
    const updateDimensions = () => {
      if (containerRef.current) {
        setDimensions({
          width: containerRef.current.offsetWidth,
          height: containerRef.current.offsetHeight,
        });
      }
    };

    updateDimensions();
    window.addEventListener('resize', updateDimensions);
    return () => window.removeEventListener('resize', updateDimensions);
  }, []);

  return (
    <div ref={containerRef} className={`w-full h-full ${activeTool === 'pan' ? 'cursor-grab' : 'cursor-crosshair'}`}>
      <Stage
        ref={stageRef}
        width={dimensions.width}
        height={dimensions.height}
        scaleX={scale}
        scaleY={scale}
        x={panX}
        y={panY}
        onWheel={handleWheel}
        onPointerDown={handlePointerDown}
        onPointerMove={handlePointerMove}
        onPointerUp={handlePointerUp}
      >
        {/* Layer for background/grid/underlays */}
        <Layer>
          {Object.values(underlayImages).map((img) => (
            <UnderlayImageRenderer
              key={img.id}
              source={img.source}
              x={img.x}
              y={img.y}
              opacity={img.opacity}
              scaleX={img.scaleX}
              scaleY={img.scaleY}
              rotation={img.rotation}
            />
          ))}
        </Layer>

        {/* Layer for vector geometry */}
        <Layer>
          {/* Render committed segments */}
          {Object.values(segments).map((seg) => (
            <Line
              key={seg.id}
              points={seg.points.flatMap((p) => [p.x, p.y])}
              stroke={selectedIds.has(seg.id) ? '#3b82f6' : '#9ca3af'}
              strokeWidth={selectedIds.has(seg.id) ? 3 : 2}
              tension={seg.geometryKind === 'spline' ? 0.5 : 0}
              hitStrokeWidth={10}
              onClick={() => {
                if (activeTool === 'select') selectObject(seg.id);
              }}
              onTap={() => {
                if (activeTool === 'select') selectObject(seg.id);
              }}
              onMouseEnter={(e) => {
                if (activeTool === 'select') {
                  const container = e.target.getStage()?.container();
                  if (container) container.style.cursor = 'pointer';
                }
              }}
              onMouseLeave={(e) => {
                if (activeTool === 'select') {
                  const container = e.target.getStage()?.container();
                  if (container) container.style.cursor = 'crosshair';
                }
              }}
            />
          ))}

          {/* Render active drafting line */}
          {isDrawing && draftPoints.length === 2 && (
            <Line
              points={[draftPoints[0].x, draftPoints[0].y, draftPoints[1].x, draftPoints[1].y]}
              stroke="#60a5fa"
              strokeWidth={2}
              dash={[5, 5]}
            />
          )}
        </Layer>
      </Stage>
    </div>
  );
};

export default Smart2Dcanvas_CanvasViewport;
